{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://medocr.local/schema/extraction_result.schema.json",
  "title": "ExtractionResult",
  "type": "object",
  "required": ["documentMeta", "patient", "procedure", "confidence", "ocr"],
  "properties": {
    "documentMeta": {
      "type": "object",
      "required": ["pages", "filename", "intakeDate"],
      "properties": {
        "pages": { "type": "integer", "minimum": 1 },
        "filename": { "type": "string" },
        "intakeDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "patient": {
      "type": "object",
      "required": ["last", "first", "dob"],
      "properties": {
        "last": { "type": "string" },
        "first": { "type": "string" },
        "dob": { "type": "string", "pattern": "^(0[1-9]|1[0-2])/(0[1-9]|[12]\\d|3[01])/\\d{4}$" },
        "phones": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string" },
        "emergencyContact": { "type": "object", "additionalProperties": true }
      }
    },
    "insurance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["carrier"],
        "properties": {
          "carrier": { "type": "string" },
          "memberId": { "type": "string" },
          "groupId": { "type": "string" },
          "status": { "type": "string", "enum": ["accepted", "not_accepted", "unknown"] }
        }
      }
    },
    "provider": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "npi": { "type": "string" },
        "practice": { "type": "string" },
        "phone": { "type": "string" },
        "fax": { "type": "string" },
        "supervising": { "type": "object", "additionalProperties": true }
      }
    },
    "procedure": {
      "type": "object",
      "required": ["cpt"],
      "properties": {
        "cpt": { "type": "string", "enum": ["95810", "95811", "G0399", "95806", "95782", "95783", "split_night"] },
        "description": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "diagnoses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" },
          "temporal": { "type": "string", "enum": ["current", "past", "resolved", "unknown"] }
        }
      }
    },
    "symptoms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["confirmed", "denied", "info"] },
          "context": { "type": "string" },
          "page": { "type": "integer", "minimum": 1 },
          "bbox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 }
        }
      }
    },
    "dme": {
      "type": "object",
      "properties": {
        "codes": { "type": "array", "items": { "type": "string" } },
        "providers": { "type": "array", "items": { "type": "string" } },
        "issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "priorStudy": {
      "type": "object",
      "properties": {
        "present": { "type": "boolean" },
        "AHI": { "type": ["number", "string"] },
        "RDI": { "type": ["number", "string"] },
        "O2": { "type": ["number", "string"] }
      }
    },
    "alerts": {
      "type": "object",
      "properties": {
        "info": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "review": { "type": "array", "items": { "type": "string" } }
      }
    },
    "flags": {
      "type": "object",
      "properties": {
        "verifyManually": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "qc": {
      "type": "object",
      "properties": {
        "nameConsistency": { "type": "string", "enum": ["pass", "fail", "unknown"] },
        "dateValidity": { "type": "string", "enum": ["pass", "fail", "unknown"] },
        "phoneValidity": { "type": "string", "enum": ["pass", "fail", "unknown"] },
        "cptValid": { "type": "string", "enum": ["pass", "fail", "unknown"] }
      }
    },
    "confidence": { "type": "string", "enum": ["High", "Medium", "Low", "Manual Review"] },
    "ocr": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["page", "text"],
        "properties": {
          "page": { "type": "integer", "minimum": 1 },
          "text": { "type": "string" },
          "boxes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bbox", "text", "conf"],
              "properties": {
                "bbox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
                "text": { "type": "string" },
                "conf": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
