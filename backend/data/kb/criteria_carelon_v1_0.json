  "general_requirements": {
    "symptoms_first": true,
    "symptoms_first_note": "Comorbidities alone are NOT sufficient — documented sleep apnea symptoms required before any testing",
    "questionnaire_or_equivalent_required": false,
    "questionnaire_note": "No specific questionnaire required, but symptom documentation is mandatory"
  },
