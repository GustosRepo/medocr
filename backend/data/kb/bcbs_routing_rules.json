{
  "_meta": {
    "description": "BCBS routing rules — affiliate profiles, TPA detection, ID format classification, 3-tier cascade config",
    "version": "1.0",
    "sources": [
      "BCBS_Complete_Payer_Knowledge_Base.md",
      "BCBS_IDFormat_ImmediateOverride.md",
      "BCBS_ThreeTier_Feedback_Architecture.md"
    ],
    "last_updated": "2026-02-27"
