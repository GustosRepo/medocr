  "decision_hierarchy": [
    { "step": 0, "name": "TPA_CHECK", "question": "Is this a Quantum Health, Benesys/Union, or other TPA plan?", "on_yes": "STOP — use TPA-specific process", "on_no": "continue" },
    { "step": 1, "name": "KNOWN_PREFIX", "question": "Is prefix in database with known rules?", "on_yes": "Use known rules", "on_no": "fall through" },
    { "step": 2, "name": "UNIVERSAL_RULES", "rules": ["letter_in_id_carelon", "medicare_supplement_no_auth"], "on_resolved": "done", "on_unresolved": "fall through" },
    { "step": 3, "name": "AFFILIATE_DEFAULTS", "action": "Use affiliate's known patterns", "if_unknown": "Call payer number on card" }
  ],
  "tpa_rules": {
    "quantum_health": {
      "detection_keywords": ["quantum health", "quantum", "CCBYQH"],
      "auth_required": false,
      "can_submit_for_documentation": true,
      "portal": "https://www.ccbyqh.com/#/",
      "phone": "800-247-8956",
      "scope": "1-2 prefixes per affiliate, employer-offered plans"
    },
    "benesys_union": {
      "detection_keywords": ["benesys", "union", "electrical workers", "pipe fitters", "ironworkers", "teamsters", "carpenters"],
      "eligibility_tools": [
        { "name": "Benesys", "url": "https://benesys-prod.webspyglass.com/logonE.jsp" },
        { "name": "Zenith", "url": "https://www.zenithadm.com/ProviderServices/ProviderLogin.cfm" }
      ],
      "auth_handlers": {
        "ICM": {
          "full_name": "Innovative Care Management",
          "submission": "upload_or_fax",
          "url": "https://innovativecare.files.com/u/file-upload",
          "auth_required_all_codes": true
        },
        "NHS": {
          "full_name": "Nevada Health Solutions",
          "submission": "portal_or_fax",
          "url": "https://nhs.acuitynxt.com/providerportal/",
          "auth_required_all_codes": true
        },
        "Telligen": {
          "submission": "portal",
          "url": "https://myqualitrac.com",
          "auth_required_all_codes": true
        }
      },
      "workflow": "Check spreadsheet first → if unknown use Benesys/Zenith to determine handler → submit through designated handler",
      "note": "White card ID can find member via Benesys with alternate ID + prefix into BCBS Eligibility"
    }
  },
  "universal_rules": {
    "letter_in_id": {
      "description": "Member ID body (after prefix) contains at least one letter → likely Carelon",
      "routing_if_true": {
        "auth_method": "carelon",
        "portal": "https://providerportal.carelon.com",
        "chat_available": true,
        "fallback": "availity_chat"
      },
      "routing_if_false": {
        "auth_method": "affiliate_specific",
        "chat_available": false
      },
      "strength": "SOFT_SIGNAL"
    },
    "medicare_supplement": {
      "description": "Benefits indicate Plan A through Plan N → true Medicare Supplement",
      "plan_codes": ["A", "B", "C", "D", "F", "G", "K", "L", "M", "N"],
      "result": { "auth_required": false, "reason": "True Medicare Supplement — no auth after Medicare" },
      "exception": "Retirement plans are NOT Medicare Supplement even if similar"
    },
    "um_fallback_phone": "800-336-7767"
  },
  "id_format_patterns": {
    "FORMAT_A": {
      "name": "Numeric Body",
      "regex": "^[A-Z]{3}\\d{6,}$",
      "signals": { "likely_carelon": false, "chat_available": false, "requires_manual_verification": true }
    },
    "FORMAT_B": {
      "name": "Alpha-Numeric Body",
      "regex": "^[A-Z]{3}[A-Z0-9]*[A-Z][A-Z0-9]*$",
      "signals": { "likely_carelon": true, "chat_available": true, "requires_manual_verification": false }
    },
    "FORMAT_C": {
      "name": "Extended Numeric",
      "regex": "^[A-Z]{3}\\d{10,}$",
      "signals": { "likely_carelon": false, "chat_available": false, "requires_manual_verification": true }
    },
    "FORMAT_FEP": {
      "name": "Federal Employee Program",
      "regex": "^R\\d{8,}$",
      "signals": { "likely_carelon": false, "chat_available": false, "requires_manual_verification": false }
    },
    "FORMAT_UNKNOWN": {
      "name": "Unrecognized",
      "regex": null,
      "signals": { "likely_carelon": null, "chat_available": null, "requires_manual_verification": true }
    }
  },
  "tool_availability_by_format": {
    "chat":              { "FORMAT_A": false, "FORMAT_B": true,  "FORMAT_C": false, "FORMAT_FEP": false },
    "phone":             { "FORMAT_A": true,  "FORMAT_B": true,  "FORMAT_C": true,  "FORMAT_FEP": true  },
    "aim_carelon_portal":{ "FORMAT_A": "sometimes", "FORMAT_B": true,  "FORMAT_C": false, "FORMAT_FEP": false },
    "fax_form":          { "FORMAT_A": true,  "FORMAT_B": true,  "FORMAT_C": false, "FORMAT_FEP": true  },
    "availity":          { "FORMAT_A": true,  "FORMAT_B": true,  "FORMAT_C": false, "FORMAT_FEP": false }
  },
  "g0399_workaround": {
    "applies_to": "Affiliates using Carelon portal EXCEPT IL and TX",
    "excluded_affiliates": ["bcbs_il", "bcbs_tx"],
    "condition": "Carelon portal doesn't accept G0399",
    "steps": ["Submit as 95810 instead", "When not reviewed/denied for in-lab study", "Drop to G0399 to bypass"],
    "portal_responses": {
      "NotReviewed": "Truly no auth required",
      "Authorized": "Authorization IS required"
    }
  },
