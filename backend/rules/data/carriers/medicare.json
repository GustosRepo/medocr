{
  "carrier": "Medicare",
  "status": "accepted",
  "synonyms": [
    "medicare",
    "cms",
    "centers for medicare",
    "medicare part b",
    "medicare b",
    "mac j1",
    "mac j",
    "primary payer"
  ],
  "patterns": {
    "memberId": [
      {
        "pattern": "^[A-Z]{1}\\d{1}[A-Z]{1}\\d{1}[A-Z]{1}\\d{4}$",
        "name": "MBI Format (New Medicare Beneficiary ID)",
        "score": 25,
        "examples": ["1EG4TE5MK73", "5W51MA5XQ16"],
        "description": "New format: Letter-Digit-Letter-Digit-Letter-4Digits"
      },
      {
        "pattern": "^[A-Z]{2,3}\\d{2,4}[A-Z0-9]{2,4}$",
        "name": "MBI Variation",
        "score": 20,
        "examples": ["AB1234CD56", "ABC12DE345", "5W51MA5XQ16"],
        "description": "2-3 letters, 2-4 digits, 2-4 alphanumeric"
      },
      {
        "pattern": "^\\d{9}[A-Z]?$",
        "name": "HICN (Legacy Health Insurance Claim Number)",
        "score": 8,
        "deprecated": true,
        "examples": ["123456789A"],
        "description": "9 digits optionally followed by letter"
      },
      {
        "pattern": "^[A-Z0-9]{9,12}$",
        "name": "Generic alphanumeric",
        "score": 5,
        "examples": ["ABC123DEF45"],
        "description": "Fallback for non-standard formats"
      }
    ],
    "groupId": [
      {
        "pattern": "^80840$",
        "name": "MAC J1 Nevada Group",
        "score": 15
      },
      {
        "pattern": "^\\d{5}$",
        "name": "Generic 5-digit group",
        "score": 5
      }
    ]
  },
  "labels": {
    "memberId": [
      "insurance id",
      "member id",
      "medicare #",
      "medicare number",
      "beneficiary id",
      "hicn",
      "mbi"
    ],
    "groupId": [
      "group",
      "group id",
      "plan",
      "mac"
    ]
  },
  "sections": {
    "preferredLocation": "insurance_section",
    "avoidLocations": ["header", "footer", "page_identifier"]
  },
  "validation": {
    "memberIdLength": {
      "min": 6,
      "max": 15
    },
    "mustHaveAlphanumeric": false,
    "cannotBeAllNumeric": false,
    "excludePatterns": [
      "^\\d{10}$",
      "^\\d{2}/\\d{2}/\\d{4}$",
      "^17027102839$"
    ]
  },
  "metadata": {
    "sunsetDate": null,
    "requiresPreauth": false,
    "notes": [
      "Medicare Part B typically does not require prior authorization for sleep studies",
      "New MBI format rolled out in 2018-2019, replacing HICN"
    ]
  }
}
